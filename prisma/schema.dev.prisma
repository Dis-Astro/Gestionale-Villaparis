generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Evento {
  id               Int              @id @default(autoincrement())
  titolo           String
  tipo             String
  dataConfermata   DateTime?
  fascia           String
  stato            String
  personePreviste  Int?
  note             String?
  menu             String?
  struttura        String?
  dateProposte     String?
  disposizioneSala String?
  luogo            String?
  prezzo           Float?
  menuPasto        String?
  menuBuffet       String?
  sposa            String?
  sposo            String?
  dataPrimoContatto    DateTime?
  canalePrimoContatto  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  clienti          EventoCliente[]
  versioni         VersioneEvento[]
  overrideLogs     OverrideLog[]
}

model VersioneEvento {
  id            String   @id @default(uuid())
  eventoId      Int
  evento        Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  numero        Int
  tipo          String
  watermark     String
  snapshot      String
  hash          String?
  autore        String?
  commento      String?
  createdAt     DateTime @default(now())
  @@index([eventoId])
}

model OverrideLog {
  id              String   @id @default(uuid())
  eventoId        Int
  evento          Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  motivo          String
  autore          String?
  campoModificato String?
  createdAt       DateTime @default(now())
  @@index([eventoId])
}

model MenuBase {
  id        Int      @id @default(autoincrement())
  nome      String
  struttura String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cliente {
  id                      Int              @id @default(autoincrement())
  nome                    String
  cognome                 String?
  email                   String?
  telefono                String?
  telefonoAlt             String?
  indirizzo               String?
  cap                     String?
  citta                   String?
  dataNascita             DateTime?
  codiceFiscale           String?
  tipoCliente             String?
  canalePrimoContatto     String?
  dataPrimoContatto       DateTime?
  secondoContattoNome     String?
  secondoContattoTelefono String?
  secondoContattoEmail    String?
  notaAnagrafica          String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  eventi    EventoCliente[]
}

model EventoCliente {
  id         Int     @id @default(autoincrement())
  evento     Evento  @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  eventoId   Int
  cliente    Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId  Int
}
