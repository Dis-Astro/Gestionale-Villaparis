generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Evento {
  id               Int              @id @default(autoincrement())
  titolo           String
  tipo             String
  dataConfermata   DateTime?
  fascia           String
  stato            String
  personePreviste  Int?
  note             String?
  menu             String?
  struttura        String?
  dateProposte     String?
  disposizioneSala String?
  disposizioneSalaPianoB String?
  pianoAttivo      String?
  luogo            String?
  prezzo           Float?
  menuPasto        String?
  menuBuffet       String?
  sposa            String?
  sposo            String?
  dataPrimoContatto    DateTime?
  canalePrimoContatto  String?
  appuntamentoOrigineId Int?
  gcalEventId      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  clienti          EventoCliente[]
  versioni         VersioneEvento[]
  overrideLogs     OverrideLog[]
  appuntamentoOrigine Appuntamento? @relation("EventoDaAppuntamento", fields: [appuntamentoOrigineId], references: [id], onDelete: SetNull)
}

model VersioneEvento {
  id            String   @id @default(uuid())
  eventoId      Int
  evento        Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  numero        Int
  tipo          String
  watermark     String
  snapshot      String
  hash          String?
  autore        String?
  commento      String?
  createdAt     DateTime @default(now())
  @@index([eventoId])
}

model OverrideLog {
  id              String   @id @default(uuid())
  eventoId        Int
  evento          Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  motivo          String
  autore          String?
  campoModificato String?
  createdAt       DateTime @default(now())
  @@index([eventoId])
}

model MenuBase {
  id        Int      @id @default(autoincrement())
  nome      String
  struttura String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cliente {
  id                      Int              @id @default(autoincrement())
  nome                    String
  cognome                 String?
  email                   String?
  telefono                String?
  telefonoAlt             String?
  indirizzo               String?
  cap                     String?
  citta                   String?
  dataNascita             DateTime?
  codiceFiscale           String?
  tipoCliente             String?
  canalePrimoContatto     String?
  dataPrimoContatto       DateTime?
  isSpam                  Boolean          @default(false)
  spamReason              String?
  spamMarkedAt            DateTime?
  secondoContattoNome     String?
  secondoContattoTelefono String?
  secondoContattoEmail    String?
  notaAnagrafica          String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  eventi    EventoCliente[]
  appuntamentiPrincipali Appuntamento[]    @relation("ClientePrincipaleAppuntamenti")
  appuntamenti          AppuntamentoCliente[]
  interazioni           InterazioneCliente[]
}

model User {
  id           String               @id @default(cuid())
  email        String               @unique
  passwordHash String
  role         String               @default("WORKER")
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  appuntamentiGestiti Appuntamento[]      @relation("OperatoreAppuntamenti")
  interazioniGestite  InterazioneCliente[]
  auditLogs           AuditLog[]
  presenzeRegistrate  PresenzaVilla[]     @relation("CreatedByPresenze")
  googleCalendar      GoogleCalendarConfig? @relation("GoogleCalendarUser")
}

model PresenzaVilla {
  id              Int       @id @default(autoincrement())
  dataRiferimento DateTime
  nome            String
  cognome         String
  azienda         String
  orarioIngresso  String
  orarioUscita    String
  motivoVisita    String
  mansioneSvolta  String
  note            String?
  meteo           String?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdByUser   User?     @relation("CreatedByPresenze", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([dataRiferimento])
  @@index([createdByUserId])
}

model Appuntamento {
  id                  Int                 @id @default(autoincrement())
  clientePrincipaleId Int
  clientePrincipale   Cliente             @relation("ClientePrincipaleAppuntamenti", fields: [clientePrincipaleId], references: [id], onDelete: Cascade)

  dataAppuntamento    DateTime
  durataMinuti        Int?                @default(0)
  esito               String?
  riassuntoColloquio  String?
  noteColloquio       String?
  numeroProgressivo   Int?
  statoFunnel         String?             @default("in_trattativa")
  datiMancanti        String?

  dateOpzionate       String?
  dataScadenzaOpzione DateTime?
  extraUnlockFinoAl   DateTime?
  statoOpzione        String?             @default("nessuna")

  operatoreId         String?
  operatore           User?               @relation("OperatoreAppuntamenti", fields: [operatoreId], references: [id], onDelete: SetNull)
  gcalEventId         String?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  clienti             AppuntamentoCliente[]
  interazioni         InterazioneCliente[]
  eventi              Evento[]            @relation("EventoDaAppuntamento")

  @@index([clientePrincipaleId])
  @@index([dataAppuntamento])
  @@index([statoFunnel])
}

model AppuntamentoCliente {
  id             Int          @id @default(autoincrement())
  appuntamentoId Int
  clienteId      Int
  ruolo          String?

  appuntamento   Appuntamento @relation(fields: [appuntamentoId], references: [id], onDelete: Cascade)
  cliente        Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([appuntamentoId])
  @@index([clienteId])
  @@unique([appuntamentoId, clienteId])
}

model InterazioneCliente {
  id               Int          @id @default(autoincrement())
  clienteId        Int
  appuntamentoId   Int?
  tipo             String
  durataMinuti     Int?         @default(0)
  sintesi          String?
  operatoreId      String?
  dataInterazione  DateTime     @default(now())
  createdAt        DateTime     @default(now())

  cliente          Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  appuntamento     Appuntamento? @relation(fields: [appuntamentoId], references: [id], onDelete: SetNull)
  operatore        User?        @relation(fields: [operatoreId], references: [id], onDelete: SetNull)

  @@index([clienteId])
  @@index([appuntamentoId])
  @@index([dataInterazione])
}

model AuditLog {
  id            String    @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  changedFields String?
  oldValue      String?
  newValue      String?
  actorId       String?
  actorRole     String?
  actorEmail    String?
  metadata      String?
  createdAt     DateTime  @default(now())

  actor         User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}

model EventoCliente {
  id         Int     @id @default(autoincrement())
  evento     Evento  @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  eventoId   Int
  cliente    Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId  Int
}


model GoogleCalendarConfig {
  id              Int      @id @default(autoincrement())
  userId          String   @unique
  user            User     @relation("GoogleCalendarUser", fields: [userId], references: [id], onDelete: Cascade)
  accessToken     String
  refreshToken    String?
  tokenExpiry     DateTime?
  calendarId      String   @default("primary")
  syncToken       String?
  connectedAt     DateTime @default(now())
  lastSyncAt      DateTime?
  isActive        Boolean  @default(true)
}

model GoogleCalendarChange {
  id              Int      @id @default(autoincrement())
  gcalEventId     String
  tipoRisorsa     String
  risorsaId       Int?
  tipoModifica    String
  dettagli        String?
  modificatoDa    String?
  stato           String   @default("pending")
  validatoDa      String?
  validatoAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([stato])
  @@index([createdAt])
}
