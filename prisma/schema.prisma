generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modello per gli eventi
model Evento {
  id               Int              @id @default(autoincrement())
  titolo           String
  tipo             String
  dataConfermata   DateTime?
  fascia           String
  stato            String
  personePreviste  Int?
  note             String?
  menu             Json?
  struttura        Json?
  dateProposte     Json?
  disposizioneSala Json?
  
  // Campi report aziendale
  luogo            String?
  prezzo           Float?
  menuPasto        String?
  menuBuffet       String?
  sposa            String?
  sposo            String?
  // Data primo contatto commerciale
  dataPrimoContatto    DateTime?
  canalePrimoContatto  String?
  appuntamentoOrigineId Int?
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  clienti          EventoCliente[]
  versioni         VersioneEvento[]
  overrideLogs     OverrideLog[]
  appuntamentoOrigine Appuntamento? @relation("EventoDaAppuntamento", fields: [appuntamentoOrigineId], references: [id], onDelete: SetNull)
}

// Versione evento - snapshot anti-contestazione
model VersioneEvento {
  id            String   @id @default(uuid())
  eventoId      Int
  evento        Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  
  numero        Int
  tipo          String
  watermark     String
  
  snapshot      Json
  hash          String?
  
  autore        String?
  commento      String?
  
  createdAt     DateTime @default(now())
  
  @@index([eventoId])
}

// Log override blocco -10 giorni
model OverrideLog {
  id            String   @id @default(uuid())
  eventoId      Int
  evento        Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  
  motivo        String
  autore        String?
  campoModificato String?
  
  createdAt     DateTime @default(now())
  
  @@index([eventoId])
}

// Modello per i menu base
model MenuBase {
  id        Int      @id @default(autoincrement())
  nome      String
  struttura Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Modello per i clienti
model Cliente {
  id                      Int              @id @default(autoincrement())
  nome                    String
  cognome                 String?
  email                   String?
  telefono                String?
  telefonoAlt             String?
  indirizzo               String?
  cap                     String?
  citta                   String?
  dataNascita             DateTime?
  codiceFiscale           String?
  // Classificazione commerciale
  tipoCliente             String?          // sposa, sposo, festeggiato, azienda, altro
  canalePrimoContatto     String?          // web, passaparola, fiera, social, altro
  dataPrimoContatto       DateTime?        // data del 1° contatto → appare in calendario
  isSpam                  Boolean          @default(false)
  spamReason              String?
  spamMarkedAt            DateTime?
  // Secondo contatto (es. sposo se il contatto primario è la sposa)
  secondoContattoNome     String?
  secondoContattoTelefono String?
  secondoContattoEmail    String?
  // Note
  notaAnagrafica          String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  eventi    EventoCliente[]
  appuntamentiPrincipali Appuntamento[]    @relation("ClientePrincipaleAppuntamenti")
  appuntamenti          AppuntamentoCliente[]
  interazioni           InterazioneCliente[]
}

model User {
  id           String               @id @default(cuid())
  email        String               @unique
  passwordHash String
  role         String               @default("WORKER")
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  appuntamentiGestiti Appuntamento[]      @relation("OperatoreAppuntamenti")
  interazioniGestite  InterazioneCliente[]
  auditLogs           AuditLog[]
  presenzeRegistrate  PresenzaVilla[]     @relation("CreatedByPresenze")
}

model PresenzaVilla {
  id              Int       @id @default(autoincrement())
  dataRiferimento DateTime
  nome            String
  cognome         String
  azienda         String
  orarioIngresso  String
  orarioUscita    String
  motivoVisita    String
  mansioneSvolta  String
  note            String?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdByUser   User?     @relation("CreatedByPresenze", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([dataRiferimento])
  @@index([createdByUserId])
}

model Appuntamento {
  id                  Int                 @id @default(autoincrement())
  clientePrincipaleId Int
  clientePrincipale   Cliente             @relation("ClientePrincipaleAppuntamenti", fields: [clientePrincipaleId], references: [id], onDelete: Cascade)

  dataAppuntamento    DateTime
  durataMinuti        Int?                @default(0)
  esito               String?
  riassuntoColloquio  String?
  noteColloquio       String?
  numeroProgressivo   Int?
  statoFunnel         String?             @default("in_trattativa")
  datiMancanti        String?

  dateOpzionate       Json?
  dataScadenzaOpzione DateTime?
  extraUnlockFinoAl   DateTime?
  statoOpzione        String?             @default("nessuna")

  operatoreId         String?
  operatore           User?               @relation("OperatoreAppuntamenti", fields: [operatoreId], references: [id], onDelete: SetNull)

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  clienti             AppuntamentoCliente[]
  interazioni         InterazioneCliente[]
  eventi              Evento[]            @relation("EventoDaAppuntamento")

  @@index([clientePrincipaleId])
  @@index([dataAppuntamento])
  @@index([statoFunnel])
}

model AppuntamentoCliente {
  id             Int          @id @default(autoincrement())
  appuntamentoId Int
  clienteId      Int
  ruolo          String?

  appuntamento   Appuntamento @relation(fields: [appuntamentoId], references: [id], onDelete: Cascade)
  cliente        Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([appuntamentoId])
  @@index([clienteId])
  @@unique([appuntamentoId, clienteId])
}

model InterazioneCliente {
  id               Int          @id @default(autoincrement())
  clienteId        Int
  appuntamentoId   Int?
  tipo             String
  durataMinuti     Int?         @default(0)
  sintesi          String?
  operatoreId      String?
  dataInterazione  DateTime     @default(now())
  createdAt        DateTime     @default(now())

  cliente          Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  appuntamento     Appuntamento? @relation(fields: [appuntamentoId], references: [id], onDelete: SetNull)
  operatore        User?        @relation(fields: [operatoreId], references: [id], onDelete: SetNull)

  @@index([clienteId])
  @@index([appuntamentoId])
  @@index([dataInterazione])
}

model AuditLog {
  id            String    @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  changedFields Json?
  oldValue      Json?
  newValue      Json?
  actorId       String?
  actorRole     String?
  actorEmail    String?
  metadata      Json?
  createdAt     DateTime  @default(now())

  actor         User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}

// Relazione N:N tra Evento e Cliente
model EventoCliente {
  id         Int     @id @default(autoincrement())
  evento     Evento  @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  eventoId   Int
  cliente    Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId  Int
}
